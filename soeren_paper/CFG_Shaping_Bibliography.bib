@article{Rotational-spectroscopy-with2014,
	abstract = {We demonstrate a new spectroscopic method for studying electronic transitions in molecules with extremely broad range of angular momentum. We employ an optical centrifuge to create narrow rotational wave packets in the ground electronic state of 16O2. Using the technique of resonance-enhanced multi-photon ionization{,} we record the spectrum of multiple ro-vibrational transitions between X3Σg− and C3Πg electronic manifolds of oxygen. Direct control of rotational excitation{,} extending to rotational quantum numbers as high as N ≳ 120{,} enables us to interpret the complex structure of rotational spectra of C3Πg beyond thermally accessible levels.},
	author = {Korobenko, Aleksey and Milner, Alexander A. and Hepburn, John W. and Milner, Valery},
	date-added = {2025-12-24 11:14:57 -0800},
	date-modified = {2025-12-24 11:14:57 -0800},
	doi = {10.1039/C3CP54598A},
	issue = {9},
	journal = {Phys. Chem. Chem. Phys.},
	pages = {4071-4076},
	publisher = {The Royal Society of Chemistry},
	title = {Rotational spectroscopy with an optical centrifuge},
	url = {http://dx.doi.org/10.1039/C3CP54598A},
	volume = {16},
	year = {2014},
	bdsk-url-1 = {http://dx.doi.org/10.1039/C3CP54598A}}

